# ============================================================
# Loop Solar — Environment Configuration
# Copy to .env and update values for your deployment
# ============================================================

# ---- Database ----
DB_NAME=loopsolar
DB_USER=loopsolar
DB_PASSWORD=CHANGE_ME_strong_password_here

# ---- MQTT ----
MQTT_INGESTION_USER=ingestion
MQTT_INGESTION_PASS=CHANGE_ME_ingestion_password
MQTT_DEVICE_USER=device
MQTT_DEVICE_PASS=CHANGE_ME_device_password

# ---- API ----
JWT_SECRET=CHANGE_ME_jwt_secret_at_least_32_chars

# ---- CORS (Frontend URL) ----
CORS_ORIGIN=https://your-dashboard.vercel.app

# ---- Node Environment ----
NODE_ENV=production
